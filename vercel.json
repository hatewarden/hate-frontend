{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/presale", "destination": "/buy", "permanent": true },
    { "source": "/presale.html", "destination": "/buy", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=()" }
      ]
    }
  ]
}
