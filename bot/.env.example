# =============================================================================
# hate-bot environment variables
# Copy to .env (locally) or set as Railway env vars (production)
# =============================================================================

# ---- Anthropic (for content generation) ----
# Reuse the same key from server/.env if you want.
ANTHROPIC_API_KEY=sk-ant-...

# ---- X / Twitter ----
# Get from developer.twitter.com → your app → keys & tokens
# Free tier is sufficient (50 tweets/day, 1500/month).
# Make sure Access Token has "Read and Write" permission.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# ---- Telegram ----
# Get from @BotFather → /newbot → save the bot token
# Add the bot as admin to the channel + group with "post messages" permission
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=@hate9000
TELEGRAM_GROUP_ID=                  # numeric -100... id; bot logs print this on first /start

# ---- Facebook Page ----
# Get from developers.facebook.com → your app → graph api explorer
# Long-lived page access token (60 days, auto-refreshes on use)
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=

# ---- Instagram (via Facebook Business) ----
# IG Business account ID — find via Graph API: /me/accounts → instagram_business_account
IG_BUSINESS_ACCOUNT_ID=
# Image hosting: Instagram requires images to be at a public URL.
# We use Cloudinary free tier for image uploads, or fall back to GitHub-hosted images.
CLOUDINARY_URL=                     # optional, format: cloudinary://<key>:<secret>@<cloud>
IMAGE_FALLBACK_BASE=https://hate.fund   # bot will use hate.fund/og.svg as fallback

# ---- Operational ----
NODE_ENV=production
PORT=3001
LAUNCH_DATE=2026-05-14T12:00:00Z   # bot stays quiet before this. set to past date to post immediately.
PAUSED=false                        # global kill-switch. set to true via /pause endpoint
DRY_RUN=false                       # if true, generate + log but don't actually post

# Post frequency (per platform, per day)
X_POSTS_PER_DAY=4
TELEGRAM_POSTS_PER_DAY=2
FACEBOOK_POSTS_PER_DAY=1
INSTAGRAM_POSTS_PER_DAY=1

# Hours of day to avoid posting (UTC). E.g., "0,1,2,3,4,5,6" = quiet 0-6am UTC
QUIET_HOURS=0,1,2,3,4,5,6

# Auth for the pause/resume admin endpoints. Pick a random string.
ADMIN_TOKEN=
